# KAO — Kalshi Analytics Optimizer
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — NEVER commit real keys.

# ─── Server-side only (never use NEXT_PUBLIC_ for these) ───────
KALSHI_API_KEY=your_kalshi_demo_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
KALSHI_ENV=demo
# Confirm exact slug against live Anthropic API before setting:
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── Public (safe to expose — mode flag only, no secret value) ──
NEXT_PUBLIC_KALSHI_ENV=demo

# ─── PROHIBITED — never add these ──────────────────────────────
# NEXT_PUBLIC_KALSHI_API_KEY=    <-- CI grep will block deploy if found
# NEXT_PUBLIC_PERPLEXITY_API_KEY= <-- CI grep will block deploy if found
# NEXT_PUBLIC_ANTHROPIC_API_KEY=  <-- CI grep will block deploy if found